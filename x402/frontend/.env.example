# --- Openfort: Project Keys (Dashboard → API Keys) ---
# Publishable key (pk_test_... or pk_live_...). Safe for client-side.
VITE_OPENFORT_PUBLISHABLE_KEY=pk_test_...
# Policy ID (pol_...) for sponsoring embedded wallet transactions. From Fee sponsorships tab.
VITE_OPENFORT_POLICY_ID=pol_...

# --- Openfort: Shield (Dashboard → Shield > API Keys) ---
# Shield publishable key for embedded wallet creation and recovery.
VITE_OPENFORT_SHIELD_PUBLISHABLE_KEY=shpk_test_...

# --- Embedded wallet recovery (optional) ---
# Backend endpoint that returns an encryption session. Required for RecoveryMethod.AUTOMATIC.
# Must point to your backend's /api/protected-create-encryption-session
VITE_CREATE_ENCRYPTED_SESSION_ENDPOINT=http://localhost:4001/api/protected-create-encryption-session

# --- WalletConnect ---
# Project ID from https://cloud.reown.com (required if using WalletConnect)
VITE_WALLET_CONNECT_PROJECT_ID=your-wallet-connect-project-id

# --- x402 paywall ---
# Backend URL of the 402-protected content. Used to fetch payment requirements and submit payments.
VITE_X402_RESOURCE_URL=http://localhost:3007/api/protected-content
# Default payment amount in USDC (e.g. 0.1)
VITE_X402_DEFAULT_AMOUNT=0.1
