# Server
PORT=3007

# --- Openfort: Project Keys (Dashboard → API Keys) ---
# Secret key (sk_test_... or sk_live_...). Required for all Openfort API calls.
OPENFORT_SECRET_KEY=

# --- Openfort: Shield (Dashboard → Shield > API Keys) ---
# Required for embedded wallet recovery. Create Shield keys and store encryption share safely.
OPENFORT_SHIELD_PUBLISHABLE_KEY=
OPENFORT_SHIELD_SECRET_KEY=
OPENFORT_SHIELD_ENCRYPTION_SHARE=

# --- Backend wallet (Option B) ---
# Create a wallet via Frontend → Backend wallet tab, then copy the env vars shown.
# WALLET_SECRET: returned when creating a backend wallet (base64 EC key)
OPENFORT_WALLET_SECRET=
# BACKEND_WALLET_ID: acc_xxx from create response. Get from UI, once created, also available in Dashboard.
OPENFORT_BACKEND_WALLET_ID=
# DELEGATED_ACCOUNT_ID: acc_xxx for gas-sponsored tx. Get from Backend wallets → wallet → Delegated Account.
OPENFORT_DELEGATED_ACCOUNT_ID=

# --- How to pay gas (backend wallet / Option B) ---
# Two mutually exclusive options:
# (1) x402 Facilitator — set X402_FACILITATOR_URL; the facilitator verifies and settles and pays gas (e.g. CDP on Base/Base Sepolia).
# (2) Openfort gas sponsorship — leave X402_FACILITATOR_URL empty; set OPENFORT_DELEGATED_ACCOUNT_ID and a fee sponsorship so Openfort pays gas.

# Options A & B: Openfort gas sponsorship (no facilitator). When X402_FACILITATOR_URL is empty, set OPENFORT_DELEGATED_ACCOUNT_ID and a fee sponsorship.
# Option A — Project-scoped: leave OPENFORT_FEE_SPONSORSHIP_ID empty; create a "Project Scoped Fee Sponsorship" in the Fee sponsorships tab.
# Option B — Transaction-scoped: set OPENFORT_FEE_SPONSORSHIP_ID to pol_xxx from the Fee sponsorships tab.
OPENFORT_FEE_SPONSORSHIP_ID=

# Option C: x402 Facilitator (facilitator mode). When X402_FACILITATOR_URL is set, the facilitator verifies and settles and pays for the settle transaction.
# Recommended: https://api.cdp.coinbase.com/platform/v2/x402 (CDP; requires CDP_API_KEY_ID + CDP_API_KEY_SECRET below).
X402_FACILITATOR_URL=
# CDP API credentials (required when using CDP facilitator). Create a Secret API Key at https://portal.cdp.coinbase.com/projects/api-keys (Ed25519 recommended).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- Payment (x402) ---
# Recipient address (0x...) that receives USDC. Use any EVM address.
PAY_TO_ADDRESS=
# Network: base-sepolia (testnet) or base (mainnet)
X402_NETWORK=base-sepolia
# URL of the 402-protected content endpoint (this server)
X402_RESOURCE=http://localhost:3007/api/protected-content
X402_DESCRIPTION=Access to premium content
X402_MIME_TYPE=application/json
# Max USDC amount (6 decimals, e.g. 100000 = 0.1 USDC)
X402_MAX_AMOUNT=100000
X402_TIMEOUT=300
# USDC contract: Base Sepolia 0x036CbD53842c5426634e7929541eC2318f3dCF7e | Base 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
X402_ASSET_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_ASSET_NAME=USDC
X402_ASSET_VERSION=2
# RPC URL (optional). Defaults: base-sepolia → https://sepolia.base.org, base → https://mainnet.base.org
X402_RPC_URL=

# CORS: comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://localhost:3007

# Optional: set to 1 for yParity signature format (debug)
# OPENFORT_SIGNATURE_YPARITY=
