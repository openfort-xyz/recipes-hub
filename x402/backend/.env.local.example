# Server Configuration
PORT=3007

# Openfort Project Keys (from dashboard: Project Settings > API Keys)
OPENFORT_SECRET_KEY=

# Openfort Shield Keys (from dashboard: Shield > API Keys)
OPENFORT_SHIELD_PUBLISHABLE_KEY=
OPENFORT_SHIELD_SECRET_KEY=
OPENFORT_SHIELD_ENCRYPTION_SHARE=


# --- Backend wallet (Option B): only these are required for x402 backend-wallet flow ---
OPENFORT_WALLET_SECRET=
OPENFORT_BACKEND_WALLET_ID=
# Optional: for gas-sponsored on-chain tx. Get from dashboard: Backend wallets > wallet > Delegated Account.
OPENFORT_DELEGATED_ACCOUNT_ID=
# Fee sponsorship: use a policy from the Fee sponsorships tab (not a backend wallet policy). For project-scoped (e.g. "Sponsor EVM Transaction" with no criteria) leave empty so the backend omits it and Openfort auto-discovers the policy.
OPENFORT_POLICY_ID=

# Payment Configuration
# Recipient of USDC (Option B: backend wallet is payer; set this to the address that receives USDC)
PAY_TO_ADDRESS=
X402_NETWORK=base-sepolia
X402_RESOURCE=http://localhost:4001/api/protected-content
X402_DESCRIPTION=Access to premium content
X402_MIME_TYPE=application/json
X402_MAX_AMOUNT=100000
X402_TIMEOUT=300
X402_ASSET_ADDRESS=
X402_ASSET_NAME=USDC
X402_ASSET_VERSION=2

# RPC URL (optional — defaults to public endpoints for the selected network)
X402_RPC_URL=

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3007
