# Openfort Project Keys (from dashboard: Project Settings > API Keys)
NEXT_PUBLIC_OPENFORT_PUBLISHABLE_KEY=your_openfort_publishable_key
NEXT_PUBLIC_OPENFORT_FEE_SPONSORSHIP_ID=your_openfort_fee_sponsorship_id

# Openfort Shield publishable key (from dashboard: Shield > API Keys)
# Passkey recovery (the default in this recipe) needs only this key — no backend.
NEXT_PUBLIC_OPENFORT_SHIELD_PUBLISHABLE_KEY=your_shield_publishable_key

# Optional — only if you switch to AUTOMATIC wallet recovery instead of passkey.
# Requires a Shield secret + encryption share and an encryption-session endpoint.
# See: https://www.openfort.io/docs/products/embedded-wallet/react/quickstart/automatic
# OPENFORT_SECRET_KEY=your_openfort_secret_key
# OPENFORT_SHIELD_SECRET_KEY=your_shield_secret_key
# OPENFORT_SHIELD_ENCRYPTION_SHARE=your_shield_encryption_share
# NEXT_PUBLIC_CREATE_ENCRYPTED_SESSION_ENDPOINT=http://localhost:3000/api/shield-session
