# Openfort Project Keys (from dashboard: Developers > API Keys)
VITE_OPENFORT_PUBLISHABLE_KEY=

# Openfort Shield Keys (from dashboard: Shield > API Keys)
VITE_OPENFORT_SHIELD_PUBLISHABLE_KEY=

# Gas sponsorship policy applied to on-chain payment actions (optional)
VITE_OPENFORT_FEE_SPONSORSHIP_ID=

# WalletConnect project id (from cloud.reown.com) — used by the wagmi connector and as the Pay app id
VITE_WALLET_CONNECT_PROJECT_ID=

# WalletConnect Pay gateway API key (from the WalletConnect dashboard, Pay section)
VITE_WALLETCONNECT_PAY_API_KEY=
