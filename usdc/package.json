{
  "name": "my-app",
  "main": "entrypoint.ts",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear --dev-client --tunnel",
    "android": "expo run:android",
    "android-no-cache": "expo run:android --no-build-cache",
    "ios": "expo run:ios",
    "ios-no-cache": "expo run:ios --no-build-cache",
    "web": "expo start --web",
    "server": "bun --watch --hot ./server/index.ts",
    "doctor": "pnpm dlx expo-doctor@latest --verbose --pnpm && pnpm expo install --fix --pnpm"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@openfort/react-native": "^1.1.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~56.0.9",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "private": true
}
