# Openfort (required) — get from https://dashboard.openfort.io/api-keys
OPENFORT_SECRET_KEY=sk_test_your-secret-key
# Required for backend-wallet signing operations
OPENFORT_WALLET_SECRET=your-wallet-secret

# Treasury wallet (required) — an Openfort EVM backend account, pre-funded with
# PathUSD on the Tempo testnet. Create one with `accounts.evm.backend.create()`
# (see lib/openfort.ts) or in the dashboard, then fund it from the Tempo faucet.
TREASURY_WALLET_ID=acc_your-treasury-account-id

# MPP (required) — Tempo address that receives the agent's payments
MPP_RECIPIENT=0x...your-tempo-recipient-address

# Optional — PathUSD contract address (default shown)
# MPP_CURRENCY=0x20c0000000000000000000000000000000000000

# Optional
NEXT_PUBLIC_BASE_URL=http://localhost:3000
