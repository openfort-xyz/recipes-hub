# Openfort project publishable key (Dashboard > Developers > API keys)
OPENFORT_PROJECT_PUBLISHABLE_KEY=YOUR_PROJECT_PUBLISHABLE_KEY

# Openfort Shield publishable key (Dashboard > Configuration > Shield)
# Required by the embedded wallet. This recipe uses PASSWORD recovery, so no
# Shield encryption-session backend is needed.
OPENFORT_SHIELD_PUBLISHABLE_KEY=YOUR_SHIELD_PUBLISHABLE_KEY

# OPTIONAL: gas sponsorship policy id (Dashboard > Configuration > Gas policies).
# Leave blank to pay gas in xDAI from the embedded wallet (a few cents on Gnosis).
OPENFORT_FEE_SPONSORSHIP_ID=

# OPTIONAL: a Pimlico API key (https://dashboard.pimlico.io) enables gasless,
# fully sponsored on-chain actions via a Pimlico smart account + paymaster.
# When set, the app sponsors create/setup/fund/spend and the "fund for gas"
# step disappears. When blank, the embedded wallet pays its own xDAI gas.
PIMLICO_API_KEY=

# OPTIONAL: Pimlico sponsorship policy id (sp_...). Gnosis is mainnet, so the
# paymaster only sponsors with a policy + a funded gas tank. Set this if your
# API key doesn't already have a default policy bound to it.
PIMLICO_SPONSORSHIP_POLICY_ID=

# OPTIONAL: override the Gnosis Chain RPC endpoint.
GNOSIS_RPC_URL=https://rpc.gnosischain.com
