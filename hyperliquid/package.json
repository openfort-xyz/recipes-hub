{
  "name": "expo-starter",
  "main": "entrypoint.ts",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client --tunnel --clear",
    "dev:ios": "expo start --ios --clear",
    "dev:android": "expo start --android --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "ios-no-cache": "expo run:ios --no-build-cache",
    "android-no-cache": "expo run:android --no-build-cache",
    "web": "pnpm dev",
    "doctor": "pnpm dlx expo-doctor@latest --verbose --pnpm && pnpm expo install --fix --pnpm"
  },
