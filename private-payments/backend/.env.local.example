# Server
PORT=3020
# Empty = allow any origin (simplest locally). In prod, list explicit origins,
# e.g. CORS_ORIGINS=http://localhost:5181
CORS_ORIGINS=

# --- Openfort (Dashboard → API Keys) — REQUIRED ---
# Secret key (sk_test_...) and publishable key (pk_test_...) from the SAME project.
# Both validate the user's session token on the Authorization header (the publishable
# key is needed to fetch the project JWKS). The backend never signs or holds keys.
OPENFORT_SECRET_KEY=
OPENFORT_PUBLISHABLE_KEY=

# --- Unlink (dashboard.unlink.xyz) — REQUIRED ---
# Server-only admin API key. Registers users and mints short-lived authorization
# tokens. Never expose this to the browser.
UNLINK_API_KEY=
# Hosted Unlink environment (chain). Defaults to monad-testnet.
UNLINK_ENVIRONMENT=monad-testnet
