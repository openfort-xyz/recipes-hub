# Openfort (client-safe) — Dashboard → API Keys / Shield → API Keys
VITE_OPENFORT_PUBLISHABLE_KEY=pk_test_...
VITE_OPENFORT_SHIELD_KEY=...

# Backend base URL (the Express service in ../backend)
VITE_API_BASE_URL=http://localhost:3020

# Unlink (client-safe)
VITE_UNLINK_ENVIRONMENT=monad-testnet
# Unlink-configured token on Monad testnet (from your Unlink dashboard → Tokens).
# This recipe was verified with a USDC test token (18 decimals).
VITE_UNLINK_TOKEN=0x...

# Monad testnet RPC (optional override)
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
