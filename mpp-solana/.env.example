# Openfort (from dashboard.openfort.io) — needed by the payer (pay / web / setup)
OPENFORT_SECRET_KEY=sk_test_...
OPENFORT_WALLET_SECRET=...
# Leave empty on first run; `pnpm setup` prints an acc_... id to paste here.
OPENFORT_SOLANA_ACCOUNT_ID=

# Merchant side (server). Only these two are required:
PAY_TO=                       # merchant Solana address that receives payment
MPP_SECRET_KEY=               # signs MPP receipts — `openssl rand -hex 32`

# Solana (defaults shown; override for localnet)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional overrides (defaults: sol / 0.001 SOL / ports 3010 + 3020)
# CURRENCY=sol
# DECIMALS=6                  # required only when CURRENCY is an SPL mint
# PRICE_BASE_UNITS=1000000
RESOURCE_URL=http://localhost:3010/api/protected
