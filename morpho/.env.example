# Openfort Project Keys (from dashboard: Project Settings > API Keys)
VITE_OPENFORT_PUBLISHABLE_KEY=

# Openfort Shield publishable key (from dashboard: Shield > API Keys)
# Passkey recovery needs only this key — no backend required.
VITE_OPENFORT_SHIELD_PUBLISHABLE_KEY=

# Fee Sponsorship and WalletConnect Configuration
VITE_OPENFORT_FEE_SPONSORSHIP_ID=
VITE_WALLET_CONNECT_PROJECT_ID=
